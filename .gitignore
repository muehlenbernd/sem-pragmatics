# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environments
.venv/
venv/
env/
.env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# pytest
.pytest_cache/
.cache/

# Generated figures (regenerated by scripts/_build_paper_notebook.py)
figures/*.pdf
figures/*.png
figures/*.svg
figures/generated/
# Except explicitly committed reference figures:
!figures/.gitkeep

# LaTeX build artifacts (regenerated by latexmk; manuscript/figures/ are kept)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc
*-blx.bib

# macOS
.DS_Store
.AppleDouble

# Editor
.idea/
.vscode/
*.swp
*.swo

# Jupyter output (optional: comment out if you want to commit outputs)
# To strip outputs before committing: nbstripout --install
